# .gcloudignore - Optimized for GitHub-based Cloud Build
# Exclude unnecessary files to speed up builds

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Logs and temporary files
*.log
.cache/
.tmp/
.turbo/
.nyc_output/

# Build artifacts (will be rebuilt)
dist/
build/
.next/
.nuxt/
.vercel/
.netlify/

# Test files (not needed for production build)
coverage/
**/__tests__/
**/*.test.ts
**/*.test.js
**/*.spec.ts
**/*.spec.js

# Documentation (keep only essential)
*.md
!README.md

# Local environment files
.env*

# Development directories
uploads/
static/

# Package manager lock files (keep only yarn.lock)
package-lock.json
pnpm-lock.yaml

# CI/CD files
.github/
.gitlab-ci.yml
.travis.yml

# Docker files (not needed for buildpack)
Dockerfile*
docker-compose*
.dockerignore

# Development scripts
scripts/test/
scripts/dev/
scripts/local/

# Include essential files for build
!package.json
!mercur/package.json
!mercur/yarn.lock
!mercur/turbo.json
!mercur/apps/backend/
!mercur/packages/
!mercur/.medusa/
!mercur/Procfile
# Exclude other project files that might confuse buildpack
b2c-marketplace-storefront/
vendor-panel/
